  "scripts": {
    "start": "vite",
    "build": "npm run build:app",
    "build:app": "vite build --sourcemap",
    "build:mobile": "vite build --sourcemap --outDir build-mobile",
    "build:seo": "npm run seo:sitemap && npm run build:app && npm run seo:prerender-annonces && npm run seo:verify",
    "mobile:sync": "npm run build:mobile && npx cap sync",
    "mobile:android:add": "npx cap add android",
    "mobile:android": "npm run build:mobile && npx cap sync android",
    "mobile:android:open": "npx cap open android",
    "mobile:ios:add": "npx cap add ios",
    "mobile:ios": "npm run build:mobile && npx cap sync ios",
    "seo:sitemap": "node scripts/generate-sitemap.cjs",
    "seo:prerender-annonces": "node scripts/prerender-annonces.cjs",
    "seo:refresh-annonces": "node scripts/deploy-preflight.cjs --require-build && npm run seo:sitemap && npm run seo:prerender-annonces && npm run seo:verify",
    "annonces:coords:backfill:dry": "node scripts/backfill-annonce-coordinates.cjs",
    "annonces:coords:backfill": "node scripts/backfill-annonce-coordinates.cjs --commit",
    "seo:verify": "node scripts/verify-seo-build.cjs",
    "test:emails": "node scripts/check-email-templates.cjs",
    "serve": "vite preview",
    "deploy": "npm run deploy:build",
    "deploy:preflight": "node scripts/deploy-preflight.cjs",
    "deploy:server": "npm run deploy:preflight && npm run deploy && node scripts/deploy-preflight.cjs --require-build && node scripts/deploy-sftp.cjs",
    "deploy:server:seo-refresh": "npm run deploy:preflight && npm run seo:refresh-annonces && node scripts/deploy-sftp.cjs",
    "deploy:server:seo-refresh:if-pending": "node scripts/deploy-seo-refresh-if-pending.cjs",
    "deploy:vercel": "npm run build:seo && echo 'Build complete! Deploy to Vercel using: npx vercel --prod'",
    "deploy:build": "npm run build:seo && echo 'Production SEO build complete! Upload the contents of the build/ folder to your web server via FTP or hosting provider file manager.'"
  },
  "eslintConfig": {
    "extends": [
